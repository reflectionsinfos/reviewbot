# Application Settings
APP_NAME="AI Tech & Delivery Review Agent"
APP_VERSION="1.0.0"
DEBUG=true

# Database
DATABASE_URL="sqlite+aiosqlite:///./reviews.db"

# API Keys (Set these in production)
OPENAI_API_KEY=""
# ELEVENLABS_API_KEY=""  # Optional for TTS

# Security
SECRET_KEY="your-secret-key-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Vector Store
CHROMA_PERSIST_DIR="./chroma_db"

# Storage
UPLOAD_DIR="./uploads"
REPORTS_DIR="./reports"

# Agent Settings
DEFAULT_LANGUAGE="en"
VOICE_ENABLED=true
REQUIRE_HUMAN_APPROVAL=true
