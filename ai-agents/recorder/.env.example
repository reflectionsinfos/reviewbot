# ─────────────────────────────────────────────────────────────────────────────
# Nexus AI — Meeting Recorder Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://recorder_user:recorder_password_change_me@localhost:5436/recorder_db

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_me_generate_a_real_secret

# ── LLM Provider (at least one required) ─────────────────────────────────────
ACTIVE_LLM_PROVIDER=anthropic        # anthropic | openai | groq | qwen | azure
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
QWEN_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# ── OBS Pipeline ─────────────────────────────────────────────────────────────
# Folder where OBS writes 2-minute mp4 segments
OBS_WATCH_FOLDER=C:/obs-output
# Whisper model: large-v3 (GPU, best accuracy) | medium (CPU, faster)
WHISPER_MODEL=large-v3
SEGMENT_DURATION_SECS=120
FILE_WATCHER_DEBOUNCE_SECS=3

# ── Vector Store ─────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Voice Interface ───────────────────────────────────────────────────────────
VOICE_ENABLED=true
# TTS provider: openai | elevenlabs | kokoro
TTS_PROVIDER=openai
# sounddevice device index for headset output (never system speakers)
# Run: python -c "import sounddevice as sd; print(sd.query_devices())" to list
TTS_OUTPUT_DEVICE_INDEX=1
TTS_VOICE=alloy                      # openai voices: alloy nova shimmer echo fable onyx
WAKE_WORD=hey nexus
ACTIVATION_HOTKEY=ctrl+space
STT_LISTEN_DURATION_SECS=8

# ── ElevenLabs (if TTS_PROVIDER=elevenlabs) ───────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Code Indexer ──────────────────────────────────────────────────────────────
# Additional paths to exclude from code indexing (comma-separated)
# Built-in exclusions: .env, node_modules, __pycache__, dist, build, .git, *.key, *.pem
CODE_INDEX_EXTRA_EXCLUSIONS=

# ── External Integrations (all optional) ─────────────────────────────────────

# Jira
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=

# GitHub / GitLab
GITHUB_TOKEN=
GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com

# Confluence
CONFLUENCE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_TOKEN=

# SharePoint / Microsoft Graph
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=

# ── Storage ───────────────────────────────────────────────────────────────────
# Local filesystem path for raw code files, mp4 segments, and export output
DATA_DIR=./data
RAW_CODE_DIR=./data/code
SEGMENTS_DIR=./data/segments
EXPORTS_DIR=./data/exports
