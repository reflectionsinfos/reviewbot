# ============================================
# AI Review Agent - Docker Environment
# Copy this to .env and configure for your environment
# ============================================

# --------------------------------------------
# Application Settings
# --------------------------------------------
APP_NAME="AI Tech & Delivery Review Agent"
DEBUG=false
APP_PORT=8000

# --------------------------------------------
# Database (PostgreSQL)
# --------------------------------------------
DATABASE_URL=postgresql+asyncpg://review_user:review_password_change_me@db:5432/reviews_db
POSTGRES_USER=review_user
POSTGRES_PASSWORD=review_password_change_me  # CHANGE IN PRODUCTION!
POSTGRES_DB=reviews_db
DB_PORT=5432

# For SQLite (development only):
# DATABASE_URL=sqlite+aiosqlite:///./reviews.db

# --------------------------------------------
# API Keys
# --------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
# ELEVENLABS_API_KEY=your-elevenlabs-key (optional)

# --------------------------------------------
# Security
# --------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --------------------------------------------
# pgAdmin (Database Management)
# --------------------------------------------
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin_change_me  # CHANGE IN PRODUCTION!
PGADMIN_PORT=5050

# --------------------------------------------
# Nginx (Production Reverse Proxy)
# --------------------------------------------
NGINX_PORT=80
NGINX_SSL_PORT=443

# --------------------------------------------
# Agent Settings
# --------------------------------------------
VOICE_ENABLED=true
REQUIRE_HUMAN_APPROVAL=true
DEFAULT_LANGUAGE=en

# --------------------------------------------
# Build Target
# --------------------------------------------
# Options: production, development
BUILD_TARGET=production
