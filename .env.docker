# =============================================================================
# ReviewBot v2.0 - Environment Configuration Template
# =============================================================================
# Copy this file to .env and configure for your environment
# copy .env.docker .env

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME="ReviewBot v2.0"
APP_VERSION="2.0.0"
DEBUG=true
ENVIRONMENT=development  # development|staging|production

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
# For Docker: Use 'db' as hostname (Docker network)
DATABASE_URL="postgresql+asyncpg://review_user:review_password_change_me@db:5432/reviews_db"

# For Local: Use 'localhost' if running outside Docker
# DATABASE_URL="postgresql+asyncpg://review_user:review_password_change_me@localhost:5432/reviews_db"

# PostgreSQL Docker Configuration
POSTGRES_USER=review_user
POSTGRES_PASSWORD=review_password_change_me  # CHANGE IN PRODUCTION!
POSTGRES_DB=reviews_db
DB_PORT=5432

# -----------------------------------------------------------------------------
# API Keys - Multiple LLM Support
# Configure ALL keys, but set ACTIVE_LLM_PROVIDER to choose which one to use
# -----------------------------------------------------------------------------

# OpenAI (Default - GPT-4, Whisper, TTS)
OPENAI_API_KEY=""  # Get from https://platform.openai.com/api-keys

# Anthropic (Claude)
ANTHROPIC_API_KEY=""  # Get from https://console.anthropic.com/

# Google (Gemini)
GOOGLE_API_KEY=""  # Get from https://makersuite.google.com/app/apikey

# GROQ (Fast LLM inference)
GROQ_API_KEY=""  # Get from https://console.groq.com/keys

# QWEN (Alibaba Cloud)
QWEN_API_KEY=""  # Get from https://dashscope.console.aliyun.com/

# Azure OpenAI
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_DEPLOYMENT=""

# ElevenLabs (Advanced TTS)
ELEVENLABS_API_KEY=""  # Get from https://elevenlabs.io/

# -----------------------------------------------------------------------------
# Active LLM Provider
# Choose ONE provider to use at a time
# Options: openai, anthropic, google, groq, qwen, azure
# -----------------------------------------------------------------------------
ACTIVE_LLM_PROVIDER="openai"  # Change this to switch LLM providers

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# CRITICAL: Generate secure random key for production!
# Python: python -c "import secrets; print(secrets.token_urlsafe(32))"
# PowerShell: -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 32 | ForEach-Object {[char]$_})

SECRET_KEY="change-this-to-a-random-secret-key-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Settings (Production: Set specific origins)
CORS_ORIGINS="*"  # Change to specific domains in production
# CORS_ORIGINS="https://your-domain.com,https://api.your-domain.com"

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
UPLOAD_DIR="./uploads"
REPORTS_DIR="./reports"
MAX_UPLOAD_SIZE_MB=25

# Voice Recordings
VOICE_UPLOAD_DIR="./uploads/voice"
VOICE_MAX_DURATION_SEC=300

# -----------------------------------------------------------------------------
# Vector Store (ChromaDB)
# -----------------------------------------------------------------------------
CHROMA_PERSIST_DIR="./chroma_db"
CHROMA_COLLECTION="review_agent"

# -----------------------------------------------------------------------------
# AI Agent Settings
# -----------------------------------------------------------------------------
DEFAULT_LANGUAGE="en"
VOICE_ENABLED=true
REQUIRE_HUMAN_APPROVAL=true  # CRITICAL: Never disable in production

# Agent Behavior
AGENT_TEMPERATURE=0.7
AGENT_MAX_TURNS=100
AGENT_TIMEOUT_MINUTES=30

# RAG Assessment
RAG_USE_LLM=false  # Use LLM for nuanced RAG assessment (slower but more accurate)

# -----------------------------------------------------------------------------
# Data Paths
# -----------------------------------------------------------------------------
DATA_DIR="./data"
TEMPLATES_DIR="./data/templates"
PROJECTS_DATA_DIR="./data/projects"

# -----------------------------------------------------------------------------
# Logging & Monitoring
# -----------------------------------------------------------------------------
LOG_LEVEL="INFO"  # DEBUG|INFO|WARNING|ERROR|CRITICAL
LOG_FORMAT="json"  # json|text
LOG_FILE="./logs/app.log"
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_CHECKLIST_OPTIMIZATION=true
FEATURE_DOMAIN_INFERENCE=true
FEATURE_VOICE_REVIEW=true
FEATURE_PDF_REPORTS=true
FEATURE_TREND_ANALYSIS=false
FEATURE_AUTONOMOUS_CODE_REVIEW=true

# -----------------------------------------------------------------------------
# Performance Tuning
# -----------------------------------------------------------------------------
# Uvicorn Workers (Production)
UVICORN_WORKERS=4
UVICORN_HOST="0.0.0.0"
UVICORN_PORT=8000

# Response Compression
COMPRESSION_ENABLED=true
COMPRESSION_MIN_SIZE=500

# -----------------------------------------------------------------------------
# Docker Configuration
# -----------------------------------------------------------------------------
APP_PORT=8000
