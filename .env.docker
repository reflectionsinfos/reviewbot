# =============================================================================
# ReviewBot v2.0 - Minimal Environment Configuration
# =============================================================================
# This file contains ONLY the variables defined in app/core/config.py
# Copy to .env and configure

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME="ReviewBot v2.0"
DEBUG=true

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
# For Docker: Use 'db' as hostname
DATABASE_URL="postgresql+asyncpg://review_user:review_password_change_me@db:5432/reviews_db"

# PostgreSQL Docker Configuration
POSTGRES_USER=review_user
POSTGRES_PASSWORD=review_password_change_me
POSTGRES_DB=reviews_db
DB_PORT=5432

# -----------------------------------------------------------------------------
# API Keys - Multiple LLM Support
# -----------------------------------------------------------------------------
# OpenAI (Required)
OPENAI_API_KEY=""

# Alternative LLMs (Optional - set ACTIVE_LLM_PROVIDER to switch)
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY=""
GROQ_API_KEY=""
QWEN_API_KEY=""
AZURE_OPENAI_API_KEY=""
ELEVENLABS_API_KEY=""

# Active LLM Provider: openai, anthropic, google, groq, qwen, azure
ACTIVE_LLM_PROVIDER="openai"

# -----------------------------------------------------------------------------
# Security Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY="change-this-to-a-random-secret-key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------------------------
# Storage Paths
# -----------------------------------------------------------------------------
DATA_DIR=/app/data
UPLOAD_DIR=/app/uploads
REPORTS_DIR=/app/reports
CHROMA_PERSIST_DIR=/app/chroma_db

# -----------------------------------------------------------------------------
# Agent Settings
# -----------------------------------------------------------------------------
VOICE_ENABLED=true
REQUIRE_HUMAN_APPROVAL=true
DEFAULT_LANGUAGE=en
