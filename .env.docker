# ReviewBot v2.0 - Environment Configuration
# Only includes variables defined in app/core/config.py

# App Info
APP_NAME="ReviewBot v2.0"
DEBUG=true

# Database
DATABASE_URL="postgresql+asyncpg://review_user:review_password_change_me@db:5432/reviews_db"

# API Keys
OPENAI_API_KEY=""
ELEVENLABS_API_KEY=""

# Security
SECRET_KEY="change-this-to-a-random-secret-key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Vector Store
CHROMA_PERSIST_DIR="./chroma_db"

# Storage
UPLOAD_DIR="./uploads"
REPORTS_DIR="./reports"

# Agent Settings
DEFAULT_LANGUAGE="en"
VOICE_ENABLED=true
REQUIRE_HUMAN_APPROVAL=true

# Data directories
DATA_DIR="./data"
TEMPLATES_DIR="./data/templates"
PROJECTS_DATA_DIR="./data/projects"
